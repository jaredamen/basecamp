# ===========================================
# Basecamp Environment Variables
# ===========================================
# Copy this file to .env.local for local development.
# On Vercel, set these in: Dashboard → Project → Settings → Environment Variables.

# --- Google OAuth ---
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# --- App URL (local dev only) ---
# Where the frontend runs. Used for OAuth callback redirects.
# On Vercel this is auto-detected from VERCEL_URL.
APP_URL=http://localhost:5173

# --- JWT Session Secret ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=

# --- OpenAI (developer's key for managed tier) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Stripe ---
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from: https://dashboard.stripe.com/webhooks (after creating the endpoint)
STRIPE_WEBHOOK_SECRET=

# --- Stripe Metered Billing ---
# Get from: Stripe Dashboard → Billing → Usage-based → your meter's price
STRIPE_METERED_PRICE_ID=
# Event name must match the meter event name in Stripe
STRIPE_METER_EVENT_NAME=ai_generation

# --- Neon Postgres ---
# Auto-set when you connect Neon to your Vercel project via the marketplace.
# For local dev, pull with: vercel env pull .env.local
# Or copy from: https://console.neon.tech → your project → Connection Details
POSTGRES_URL=
