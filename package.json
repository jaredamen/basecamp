{
  "name": "basecamp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "type-check": "tsc -b --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --exclude 'src/components/__tests__/{VoiceSettings,AudioPlayer,FlashcardViewer}.test.*'",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "e2e:onboarding": "playwright test e2e/05-onboarding-flow.spec.ts e2e/06-profile-management.spec.ts",
    "clips:record": "playwright test --config=clips/playwright.config.ts",
    "clips:record:headed": "playwright test --config=clips/playwright.config.ts --headed",
    "clips:convert": "node clips/scripts/convert.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.24",
    "jose": "^6.2.2",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stripe": "^22.0.0",
    "tailwindcss": "^3.4.15",
    "uuid": "^13.0.0",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.1",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
